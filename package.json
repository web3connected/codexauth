{
  "name": "codexauth",
  "version": "0.1.0",
  "private": true,
  "description": "CodexAuth - Zone-Aware Authentication Developer Portal",
  "homepage": "https://codexauth.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/web3connected/codexauth.git"
  },
  "scripts": {
    "codex:publish": "bash scripts/copy-components.sh",
    "dev": "next dev --turbopack -p 3003",
    "dev:stable": "NODE_OPTIONS='--max-old-space-size=4096' next dev --turbopack -p 3003",
    "dev:pm2": "pm2 start ecosystem.config.js",
    "dev:stop": "pm2 stop codexauth-dev",
    "dev:restart": "pm2 restart codexauth-dev",
    "dev:logs": "pm2 logs codexauth-dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3003}",
    "lint": "next lint",
    "test": "python3 scripts/testing/run_tests.py",
    "test:quick": "make quick",
    "test:full": "make full",
    "test:kat": "make test",
    "benchmark": "make benchmark",
    "setup:test": "make setup",
    "deploy:simple": "./scripts/deployment/deploy-simple.sh",
    "deploy:prod": "./scripts/deployment/deploy_production.sh",
    "start:services": "./scripts/management/start_codexauth.sh",
    "stop:services": "./scripts/management/stop_codexauth.sh",
    "status": "python3 scripts/management/check_status.py"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.51.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.539.0",
    "prism-react-renderer": "^2.4.1",
    "next": "^15.4.6",
    "next-themes": "^0.4.6",
    "pg": "^8.11.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.1.2",
    "swiper": "^12.0.3",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.10.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "pm2": "^5.4.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
